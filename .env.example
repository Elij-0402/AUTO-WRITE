# Supabase — required for auth + optional cloud sync
# Get these from your Supabase project settings: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Base URL of this app deployment — used by auth email-redirect links.
# Local dev: http://localhost:3000
# Production: your deployed URL, no trailing slash
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI provider API keys are BYOK (Bring Your Own Key) — configured per-project
# via the in-app AIConfigDialog. They are stored ONLY in the browser's IndexedDB
# and never sent to the server. Do NOT set provider keys here.
